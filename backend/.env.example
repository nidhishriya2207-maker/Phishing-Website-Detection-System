# Server Configurations
PORT=5000

# Database Configurations (MongoDB Atlas URI or Local MongoDB Connection)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/phishing_detection?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/phishing_detection

# Threat Intelligence APIs (Optional)
# Get a free key from Google Cloud Console to enable Safe Browsing Lookup
GOOGLE_SAFE_BROWSING_API_KEY=
